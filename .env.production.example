# Production. Do not copy this file to Git or use the example secret.
NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?schema=public
SESSION_SECRET=replace-with-long-random-secret
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
FRONTEND_ORIGINS=https://app.example.com
TRUST_PROXY=true
SERVE_STATIC_FRONTEND=false
UPLOAD_DIR=/app/uploads/products
MAX_UPLOAD_MB=2
STAGING_ENVIRONMENT=false
PREPRODUCTION_ENVIRONMENT=false
STAGING_LOCAL=false
LOGIN_RATE_LIMIT_MAX=10
REQUIRE_NO_DEMO_USERS=true

# Stripe — obtén tus claves en https://dashboard.stripe.com/apikeys
# Usa sk_test_ para staging, sk_live_ para producción
STRIPE_SECRET_KEY=sk_live_replace_with_real_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_real_secret
# URL pública de la app — usada para generar success_url y cancel_url de Stripe
PUBLIC_APP_URL=https://app.example.com
