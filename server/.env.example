NODE_ENV=development
DATABASE_URL="file:./dev.db"
PORT=4000
FRONTEND_ORIGINS="http://127.0.0.1:5173,http://localhost:5173"
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
SESSION_SECRET=replace-with-a-long-random-secret
TRUST_PROXY=false
LOGIN_RATE_LIMIT_MAX=10

# Logging — pino (opcional en dev, recomendado en prod)
# Niveles: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Email — Resend (https://resend.com)
# En desarrollo, si no configuras RESEND_API_KEY los emails se omiten y se loguean en consola.
# En producción es obligatorio.
RESEND_API_KEY=re_replace_with_your_api_key
EMAIL_FROM=Tic Toc Pharma <pedidos@tudominio.com>

# Stripe — usa claves TEST para desarrollo (sk_test_...)
# Obtén tus claves en https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_replace_with_your_test_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_webhook_secret
# Para pruebas locales de webhook instala Stripe CLI y ejecuta:
#   stripe listen --forward-to http://127.0.0.1:4000/api/payments/webhook
PUBLIC_APP_URL=http://127.0.0.1:5173
