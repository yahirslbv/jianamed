generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  passwordHash        String
  // SQLite keeps enum values as text. The PostgreSQL production schema uses UserRole.
  role                String               @default("CLIENT")
  isActive            Boolean              @default(true)
  forcePasswordChange Boolean              @default(false)
  customer            Customer?
  orders              Order[]
  auditLogs           AuditLog[]
  sessions            Session[]
  importBatches       ImportBatch[]
  passwordResetTokens PasswordResetToken[]
  pendingCheckouts    PendingCheckout[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([role, isActive])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Customer {
  id               String   @id @default(cuid())
  userId           String   @unique
  businessName     String
  commercialName   String?
  rfc              String?
  contactName      String
  phone            String
  address          String
  city             String
  state            String
  postalCode       String
  sanitaryLicense  String?
  isAuthorized     Boolean  @default(true)
  // Virtual credit is prepared for a later stage and does not affect checkout yet.
  creditEnabled    Boolean  @default(false)
  creditLimitCents Int      @default(0)
  creditUsedCents  Int      @default(0)
  creditStatus     String   @default("DISABLED")
  // Customers and users are deactivated instead of deleted. Restrict protects order history.
  user             User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  orders           Order[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([rfc])
  @@index([isAuthorized])
}

model Laboratory {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  isActive    Boolean   @default(true)
  products    Product[]
  offers      Offer[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  isActive    Boolean   @default(true)
  products    Product[]
  offers      Offer[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id                           String         @id @default(cuid())
  sku                          String         @unique
  commercialName               String
  genericName                  String
  activeIngredient             String
  laboratoryId                 String
  categoryId                   String
  pharmaceuticalForm           String
  concentration                String
  presentation                 String
  sanitaryRegistration         String?
  healthFraction               String         @default("NOT_APPLICABLE")
  requiresPrescription         Boolean        @default(false)
  requiresRetainedPrescription Boolean        @default(false)
  isControlled                 Boolean        @default(false)
  productType                  String
  priceCents                   Int
  stock                        Int            @default(0)
  imageUrl                     String?
  description                  String?
  isActive                     Boolean        @default(true)
  laboratory                   Laboratory     @relation(fields: [laboratoryId], references: [id], onDelete: Restrict)
  category                     Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  inventoryLots                InventoryLot[]
  orderItems                   OrderItem[]
  offers                       Offer[]
  createdAt                    DateTime       @default(now())
  updatedAt                    DateTime       @updatedAt

  @@index([laboratoryId])
  @@index([categoryId])
  @@index([commercialName])
  @@index([productType])
  @@index([healthFraction])
  @@index([isActive])
  @@index([stock])
}

model Offer {
  id                    String      @id @default(cuid())
  title                 String
  description           String?
  discountType          String
  discountValueCents    Int?
  discountPercentageBps Int?
  startsAt              DateTime
  endsAt                DateTime
  isActive              Boolean     @default(true)
  productId             String?
  laboratoryId          String?
  categoryId            String?
  productType           String?
  product               Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  laboratory            Laboratory? @relation(fields: [laboratoryId], references: [id], onDelete: SetNull)
  category              Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([isActive, startsAt, endsAt])
  @@index([productId])
  @@index([laboratoryId])
  @@index([categoryId])
  @@index([productType])
}

model InventoryLot {
  id                String   @id @default(cuid())
  productId         String
  lotNumber         String
  expirationDate    DateTime
  quantity          Int
  warehouseLocation String
  product           Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([productId, lotNumber])
}

model Order {
  id                  String      @id @default(cuid())
  folio               String      @unique
  userId              String
  customerId          String
  clientName          String?
  clientEmail         String?
  status              String      @default("PENDING_REVIEW")
  subtotalCents       Int
  discountTotalCents  Int         @default(0)
  totalCents          Int
  deliveryAddress     String?
  deliveryCity        String?
  deliveryState       String?
  deliveryPostalCode  String?
  billingBusinessName String?
  billingRfc          String?
  billingAddress      String?
  responsibleName     String?
  responsiblePhone    String?
  observations        String?
  // Payment tracking — populated once Stripe confirms the charge
  paymentStatus       String      @default("PENDING_PAYMENT")
  stripeSessionId     String?     @unique
  paidAt              DateTime?
  paymentMethod       String?
  user                User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  customer            Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items               OrderItem[]
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([userId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id                     String  @id @default(cuid())
  orderId                String
  productId              String
  sku                    String
  productName            String
  laboratoryName         String
  presentation           String
  quantity               Int
  unitPriceCents         Int
  originalUnitPriceCents Int     @default(0)
  discountAmountCents    Int     @default(0)
  offerTitle             String?
  subtotalCents          Int
  order                  Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product                Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  details   String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
  @@index([userId, createdAt])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  sessionTokenHash String    @unique
  expiresAt        DateTime
  userAgent        String?
  ipAddress        String?
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model ImportBatch {
  id          String    @id @default(cuid())
  userId      String?
  type        String
  filename    String?
  status      String    @default("PENDING")
  totalRows   Int       @default(0)
  validRows   Int       @default(0)
  errorRows   Int       @default(0)
  createdRows Int       @default(0)
  updatedRows Int       @default(0)
  errorsJson  String?
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model OrderFolioSequence {
  year      Int      @id
  nextValue Int      @default(0)
  updatedAt DateTime @updatedAt
}

// Temporary store: cart + checkout data while the client completes Stripe Checkout.
// Created when the Stripe session is opened; deleted when the webhook confirms payment.
model PendingCheckout {
  id              String   @id @default(cuid())
  userId          String
  stripeSessionId String   @unique
  cartJson        String   // JSON: [{productId, quantity}]
  checkoutJson    String   // JSON: delivery + billing fields
  observations    String?
  expiresAt       DateTime // matches Stripe session expiry (~30 min)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeSessionId])
  @@index([expiresAt])
}
