# Public preproduction. Copy to .env.preproduction only on a controlled machine;
# hosting providers should configure these values in their encrypted environment UI.
NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?schema=public
SESSION_SECRET=replace-with-long-random-secret
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
FRONTEND_ORIGINS=https://staging.example.com
TRUST_PROXY=true
SERVE_STATIC_FRONTEND=false
UPLOAD_DIR=/app/uploads/products
MAX_UPLOAD_MB=2
STAGING_ENVIRONMENT=true
PREPRODUCTION_ENVIRONMENT=true
STAGING_LOCAL=false
LOGIN_RATE_LIMIT_MAX=10
# Set only when the API is already reachable and preprod:check should probe it.
# PREPROD_CHECK_API_URL=https://api-staging.example.com
# Set true only after demo accounts have been removed or disabled.
REQUIRE_NO_DEMO_USERS=true
