{
  "name": "tic-toc-pharma-catalog",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "dev:server": "node --watch server/index.js",
    "prisma:generate": "npm run prisma:generate:sqlite",
    "prisma:generate:sqlite": "prisma generate --schema server/prisma/schema.prisma",
    "prisma:generate:postgres": "prisma generate --schema server/prisma/postgresql/schema.prisma",
    "prisma:migrate": "node scripts/ensure-local-sqlite.js && prisma migrate dev --schema server/prisma/schema.prisma",
    "prisma:migrate:deploy": "node scripts/ensure-local-sqlite.js && prisma migrate deploy --schema server/prisma/schema.prisma",
    "prisma:migrate:deploy:postgres": "node scripts/prisma-postgres.js migrate-deploy",
    "prisma:studio": "prisma studio --schema server/prisma/schema.prisma",
    "prisma:studio:postgres": "node scripts/prisma-postgres.js studio",
    "prisma:seed": "prisma db seed --schema server/prisma/schema.prisma",
    "prisma:seed:postgres": "npm run prisma:generate:postgres && node scripts/staging-seed.js",
    "db:seed": "npm run prisma:seed",
    "db:migrate:deploy": "npm run prisma:migrate:deploy:postgres",
    "db:studio": "npm run prisma:studio",
    "db:backup:local": "node scripts/db-backup-local.js",
    "db:restore:local": "node scripts/db-restore-local.js",
    "postgres:up": "node scripts/postgres-compose.js up",
    "postgres:down": "node scripts/postgres-compose.js down",
    "postgres:logs": "node scripts/postgres-compose.js logs",
    "staging:check": "npm run prisma:generate:postgres && node scripts/staging-check.js",
    "staging:server": "npm run prisma:generate:postgres && node scripts/staging-server.js",
    "staging:smoke": "node scripts/staging-smoke-test.js",
    "preprod:check": "node scripts/preprod-check.js",
    "bootstrap:admin": "node scripts/bootstrap-admin.js",
    "seed:safe": "node scripts/seed-safe.js",
    "test": "node --import ./server/tests/setup.js --test --test-concurrency=1 server/tests/money.test.js server/tests/orderHelpers.test.js server/tests/auth.test.js server/tests/catalog.test.js server/tests/orders.test.js server/tests/salesPeriods.test.js server/tests/security.test.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "multer": "^2.2.0",
    "pdfkit": "^0.19.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "resend": "^4.0.0",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.19.3",
    "vite": "^7.0.0"
  },
  "prisma": {
    "seed": "node server/prisma/seed.js"
  }
}
