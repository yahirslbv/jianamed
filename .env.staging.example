# Local PostgreSQL staging only. Copy to .env.staging and replace SESSION_SECRET.
STAGING_ENVIRONMENT=true
STAGING_LOCAL=true
NODE_ENV=production
PORT=4000
DATABASE_URL="postgresql://tictoc_staging:tictoc_staging_password@localhost:5432/tictocpharma_staging?schema=public"
SESSION_SECRET=change-this-to-a-long-random-staging-only-secret
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
FRONTEND_ORIGINS="http://127.0.0.1:5173,http://localhost:5173"
TRUST_PROXY=false
SERVE_STATIC_FRONTEND=false
UPLOAD_DIR=server/uploads/products
MAX_UPLOAD_MB=2
LOGIN_RATE_LIMIT_MAX=10
STAGING_API_URL="http://127.0.0.1:4000"
